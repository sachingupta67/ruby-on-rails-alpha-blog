<h1>Articles List</h1>
<table>
  <thead>
    <tr>
      <th>S.No</th>
      <th>Title</th>
      <th>Description</th> 
      <th colspan='3'>Actions</th>
    </tr>
  </thead>
  <tbody>
  <% @articles.each do |article|  %>
    <tr>
      <td><%= article.id %></td>
      <td><%= article.title %></td>
      <td><%= article.description %></td>
      <td><%= link_to 'Show', article_path(article) %>
      <td><%= link_to 'Edit', edit_article_path(article) %>
      <td><%= link_to 'Delete', article_path(article), method: :delete, data: { turbo_method: :delete, turbo: false,confirm: "Are you sure you want to delete this article?" } %></td>
    </tr>
    <% end%>  
  </tbody>
</table>
<%= link_to 'Create new article', new_article_path %>
